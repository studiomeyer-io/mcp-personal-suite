{
  "name": "mcp-personal-suite",
  "version": "0.5.4",
  "description": "Local-first personal productivity MCP server for Claude, Cursor, and any MCP client. Email, Calendar, Messaging, Search, Image Generation. BYOK, no cloud, no signup.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "personal-suite": "dist/server.js",
    "mcp-personal-suite": "dist/server.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "start:http": "node dist/server.js --http",
    "dev": "tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@slack/bolt": "^4.6.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "discord.js": "^14.0.0",
    "googleapis": "^148.0.0",
    "grammy": "^1.41.0",
    "imapflow": "^1.2.18",
    "mailparser": "^3.9.4",
    "nodemailer": "^8.0.2",
    "ts-caldav": "^0.3.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.5",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "overrides": {
    "protobufjs": "^7.5.5"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "cursor",
    "email",
    "calendar",
    "messaging",
    "telegram",
    "discord",
    "slack",
    "whatsapp",
    "search",
    "image-generation",
    "byok",
    "local-first",
    "self-hosted",
    "personal-assistant"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/studiomeyer-io/mcp-personal-suite"
  },
  "homepage": "https://github.com/studiomeyer-io/mcp-personal-suite",
  "bugs": {
    "url": "https://github.com/studiomeyer-io/mcp-personal-suite/issues"
  },
  "author": "StudioMeyer <hello@studiomeyer.io>"
}
